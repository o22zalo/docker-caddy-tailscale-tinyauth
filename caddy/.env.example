# =============================================================================
# caddy/.env.example — biến môi trường cho Caddy (caddy-docker-proxy)
# =============================================================================
#
# Mục đích: tài liệu env của lucaslorentz/caddy-docker-proxy + cổng publish
# của stack. Compose đọc root .env; copy KEY cần dùng vào đó.
#
# Tài liệu chính:
#   - caddy-docker-proxy Options:
#     https://github.com/lucaslorentz/caddy-docker-proxy#options
#   - Caddy docs: https://caddyserver.com/docs/
#   - Labels → Caddyfile:
#     https://github.com/lucaslorentz/caddy-docker-proxy#labels-to-caddyfile-conversion
#   - Image: https://hub.docker.com/r/lucaslorentz/caddy-docker-proxy
#   - Tinyauth snippet: https://tinyauth.app/docs/community/caddy/
#
# Trong dự án:
#   caddy/caddy.yml dùng: CADDY_HTTP_PORT, CADDY_HTTPS_PORT, CADDY_INGRESS_NETWORKS=proxy
#   Label snippet tinyauth_forwarder được hard-code trên service caddy.
#
# Profiles: caddy | core | full  (bật qua COMPOSE_PROFILES ở root .env)
# =============================================================================

# -----------------------------------------------------------------------------
# Profiles (đặt ở ROOT .env — Compose đọc COMPOSE_PROFILES toàn project)
# -----------------------------------------------------------------------------
# COMPOSE_PROFILES=core
# COMPOSE_PROFILES=caddy
# Docs: https://docs.docker.com/compose/how-tos/profiles/

# -----------------------------------------------------------------------------
# Cổng publish ra host (biến stack — compose ports:)
# -----------------------------------------------------------------------------

# CADDY_HTTP_PORT
#   Công dụng: Map port host → container :80 (HTTP origin; Tunnel thường dùng cái này).
#   Prod: 80. CI (docker-compose.ci.yml): override 8080:80.
CADDY_HTTP_PORT=80

# CADDY_HTTPS_PORT
#   Công dụng: Map host → container :443.
#   Với Cloudflare Tunnel terminate TLS, có thể không cần public 443 trên host.
CADDY_HTTPS_PORT=443

# -----------------------------------------------------------------------------
# caddy-docker-proxy — mode & mạng
# -----------------------------------------------------------------------------

# CADDY_DOCKER_MODE  [chọn 1 giá trị]
#   Công dụng: Chế độ chạy plugin docker-proxy.
#   Giá trị hợp lệ:
#     standalone  — Mặc định. Vừa controller (đọc Docker) vừa server (proxy).
#                   Khuyến nghị cho stack 1 node như dự án này.
#     controller  — Chỉ quét Docker và đẩy config tới server nodes (Swarm multi-node).
#     server      — Chỉ nhận config từ controller, serve traffic (cần label
#                   caddy_controlled_server + CADDY_CONTROLLER_NETWORK).
#   Mặc định: standalone
CADDY_DOCKER_MODE=standalone

# CADDY_INGRESS_NETWORKS
#   Công dụng: Danh sách network (phẩy) mà Caddy coi là ingress — chỉ proxy
#   container gắn các network này. Tránh tự detect sai khi multi-network.
#   Stack này: bắt buộc `proxy` (khớp networks/networks.yml).
#   Ví dụ nhiều net: proxy,frontend
CADDY_INGRESS_NETWORKS=proxy

# CADDY_CONTROLLER_NETWORK
#   Công dụng: CIDR mạng controller được phép cấu hình server (mode distributed).
#   Ví dụ: 10.200.200.0/24
#   Không cần khi standalone.
# CADDY_CONTROLLER_NETWORK=

# -----------------------------------------------------------------------------
# Docker API / socket
# -----------------------------------------------------------------------------

# CADDY_DOCKER_SOCKETS
#   Công dụng: Socket Docker (phẩy nếu nhiều). Mặc định: unix socket host.
#   Ví dụ: unix:///var/run/docker.sock
# CADDY_DOCKER_SOCKETS=

# CADDY_DOCKER_CERTS_PATH
#   Công dụng: Đường dẫn cert TLS cho remote Docker API (một entry / socket).
# CADDY_DOCKER_CERTS_PATH=

# CADDY_DOCKER_APIS_VERSION
#   Công dụng: Pin Docker API version (phẩy nếu multi-socket).
# CADDY_DOCKER_APIS_VERSION=

# DOCKER_HOST / DOCKER_API_VERSION / DOCKER_CERT_PATH / DOCKER_TLS_VERIFY
#   Công dụng: Biến chuẩn client Docker (khi không mount sock local).
#   Docs: https://docs.docker.com/engine/reference/commandline/cli/#environment-variables
# DOCKER_HOST=
# DOCKER_TLS_VERIFY=

# CADDY_DOCKER_NO_SCOPE  [true|false]
#   Công dụng: Tắt Docker event scope filter (hữu ích Podman).
#   Mặc định: false
# CADDY_DOCKER_NO_SCOPE=false

# -----------------------------------------------------------------------------
# Caddyfile generation
# -----------------------------------------------------------------------------

# CADDY_DOCKER_CADDYFILE_PATH
#   Công dụng: File Caddyfile gốc được ghép thêm site sinh từ labels.
# CADDY_DOCKER_CADDYFILE_PATH=

# CADDY_DOCKER_ENVFILE
#   Công dụng: File KEY=VALUE nạp vào process Caddy.
# CADDY_DOCKER_ENVFILE=

# CADDY_DOCKER_LABEL_PREFIX
#   Công dụng: Prefix label Docker (mặc định `caddy`). Đổi nếu conflict.
#   Mặc định: caddy
# CADDY_DOCKER_LABEL_PREFIX=caddy

# CADDY_DOCKER_PROXY_SERVICE_TASKS  [true|false]
#   Công dụng (Swarm):
#     true  — Proxy tới IP từng task (mặc định plugin).
#     false — Proxy DNS name service load balancer.
#   Compose non-swarm: ít ảnh hưởng; giữ mặc định.
# CADDY_DOCKER_PROXY_SERVICE_TASKS=true

# CADDY_DOCKER_PROCESS_CADDYFILE  [true|false]
#   Công dụng:
#     true  — Xử lý Caddyfile, bỏ server block lỗi trước khi load (mặc định).
#     false — Load nguyên; lỗi config có thể làm reload fail.
# CADDY_DOCKER_PROCESS_CADDYFILE=true

# CADDY_DOCKER_SCAN_STOPPED_CONTAINERS  [true|false]
#   Công dụng:
#     false — Chỉ container đang chạy (mặc định, khuyến nghị).
#     true  — Quét cả container stopped (giữ label/site khi tạm stop).
# CADDY_DOCKER_SCAN_STOPPED_CONTAINERS=false

# CADDY_DOCKER_POLLING_INTERVAL
#   Công dụng: Chu kỳ poll Docker nếu miss event (ví dụ 30s).
#   Mặc định: 30s
# CADDY_DOCKER_POLLING_INTERVAL=30s

# CADDY_DOCKER_EVENT_THROTTLE_INTERVAL
#   Công dụng: Gộp event Docker trước khi regenerate Caddyfile (ví dụ 100ms).
#   Mặc định: 100ms
# CADDY_DOCKER_EVENT_THROTTLE_INTERVAL=100ms

# -----------------------------------------------------------------------------
# Logging & admin API
# -----------------------------------------------------------------------------

# CADDY_DOCKER_LOG_LEVEL  [chọn 1 giá trị]
#   Công dụng: Log level plugin docker-proxy.
#   Giá trị hợp lệ:
#     DEBUG — Chi tiết regenerate/label (debug).
#     INFO  — Thông tin vận hành.
#     WARN  — Cảnh báo.
#     ERROR — Chỉ lỗi.
#   Để trống = giữ default Caddy.
# CADDY_DOCKER_LOG_LEVEL=INFO

# CADDY_DOCKER_LOG_FORMAT  [chọn 1 giá trị]
#   Công dụng: Định dạng log.
#   Giá trị hợp lệ:
#     console — Dễ đọc trên terminal (dev).
#     json    — Structured log (SIEM/aggregation).
#   Để trống = default Caddy.
# CADDY_DOCKER_LOG_FORMAT=console

# CADDY_ADMIN
#   Công dụng: Địa chỉ admin API Caddy, hoặc `off` để tắt.
#   Mặc định Caddy: localhost:2019
#   Giá trị thường:
#     localhost:2019 — Chỉ trong container (an toàn hơn).
#     0.0.0.0:2019   — Expose admin (NGUY HIỂM nếu public).
#     off            — Tắt admin API.
# CADDY_ADMIN=localhost:2019

# -----------------------------------------------------------------------------
# Gợi ý label site (không phải env process — cấu hình trên service upstream)
# -----------------------------------------------------------------------------
# caddy: http://app.example.com
# caddy.reverse_proxy: "{{upstreams 80}}"
# caddy.import: tinyauth_forwarder *
