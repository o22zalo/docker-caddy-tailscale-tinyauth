# =============================================================================
# orchestrator/.env.example — Catalog biến môi trường cho sidecar orchestrator
# =============================================================================
#
# Copy các dòng cần dùng sang .env gốc của repo (KHÔNG commit secret thật).
# Sidecar chỉ hoạt động khi CONSUL_ENABLE=1.
#
# MÔ HÌNH: RTDB làm "consul" điều phối leader (đang phục vụ) / con (standby).
#   ① start OK      → ghi trạng thái node lên RTDB (giờ, máy, meta từ env)
#   ② lắng nghe path → node mới ready → stop cloudflared + upload dữ liệu...
#   ③ handoff        → chuyền traffic qua named tunnel (cùng domain)
# =============================================================================

# ── Bật/tắt toàn bộ orchestration ───────────────────────────────────────────
# 0 = tắt (sidecar idle, chỉ ghi 1 node record để quan sát)
# 1 = bật (election + heartbeat + handoff)
# CONSUL_ENABLE=1

# ── Firebase Realtime Database (bắt buộc khi CONSUL_ENABLE=1) ─────────────────
# Service Account JSON, mã hoá base64. Tạo bằng:
#   base64 -w0 service-account.json    (Linux)
#   base64 service-account.json | tr -d '\n'   (macOS)
# LƯU Ý: đây là SECRET — đặt qua secret store CI (secrets.ENV_FILE), không commit.
# ORCH_RTDB_SERVICE_ACCOUNT=<base64-service-account-json>

# Database URL (không phải project URL). VD:
#   https://<project-id>-default-rtdb.firebaseio.com
#   https://<project-id>-default-rtdb.asia-southeast1.firebasedatabase.app
# ORCH_RTDB_URL=https://<project-id>-default-rtdb.firebaseio.com

# Namespace consul trong RTDB → /orchestrator/<ORCH_STACK>/...
# Mặc định = DOMAIN. Đặt riêng nếu 1 project RTDB điều phối nhiều stack.
# ORCH_STACK=example.com

# ── Danh tính node (YÊU CẦU ①) ───────────────────────────────────────────────
# Bỏ trống để tự sinh từ CI (github-<runId>-<attempt> / azure-<buildId>-<attempt>).
# ORCH_NODE_ID=github-12345-1

# URL public hiện tại (named tunnel: chính là https://<DOMAIN>). Ghi lên RTDB.
# ORCH_PUBLIC_URL=https://whoami.example.com

# Mọi biến ORCH_META_* sẽ tự động vào node.meta.<key> trên RTDB.
# "có thể cấu hình các thông tin cần thiết vào đây" — thêm bao nhiêu tuỳ ý:
# ORCH_META_REGION=asia-southeast1
# ORCH_META_ENV=production
# ORCH_META_TEAM=platform
# ORCH_META_NOTE=blue-green

# ── Timing / handoff tuning ──────────────────────────────────────────────────
ORCH_HEARTBEAT_INTERVAL_SECONDS=15   # nhịp đập heartbeat
ORCH_HEARTBEAT_TTL_SECONDS=90        # quá hạn này → coi node/leader là chết
ORCH_ACQUIRE_INTERVAL_SECONDS=5      # standby cố giành ghế mỗi Xs
ORCH_RENEW_INTERVAL_SECONDS=10       # leader gia hạn ghế mỗi Xs
ORCH_READY_SERVICE=cloudflared       # service quyết định "stack ready"
ORCH_READY_TIMEOUT_SECONDS=180

# Chủ động nhường ghế TRƯỚC khi job CI hết 60' (đặt < 3600). Mặc định 3300 (55').
ORCH_MAX_LEADER_SECONDS=3300
# =1 để ép handoff ngay khi thấy successor (dùng test / blue-green thủ công).
# ORCH_FORCE_HANDOFF=1
# =1 để container sidecar tự thoát sau khi nhường ghế xong.
# ORCH_EXIT_AFTER_HANDOFF=1

# ── Compose control (sidecar toàn quyền) ─────────────────────────────────────
# COMPOSE_PROJECT_NAME=proxy-stack
# File compose để thao tác. PROD dùng named tunnel → docker-compose.yml.
ORCH_COMPOSE_FILES=docker-compose.yml
ORCH_CF_SERVICE=cloudflared          # service cloudflared để stop khi handoff
ORCH_CF_STOP_GRACE=35                # grace khớp stop_grace_period của cloudflared

# ── Hook upload dữ liệu (YÊU CẦU ②) ──────────────────────────────────────────
# Lệnh tuỳ ý chạy trong /workspace khi handoff (đẩy dữ liệu lên). Bỏ trống =
# dùng mặc định best-effort (litestream tự replicate + rclone). VD:
# ORCH_UPLOAD_CMD=node scripts/backup.mjs && docker compose exec -T litestream litestream snapshots
# ORCH_UPLOAD_CMD=node scripts/backup.mjs
# ORCH_RCLONE_SERVICE=rclone
# ORCH_RCLONE_PUSH_CMD=rclone sync /data remote:path

# Webhook tuỳ chọn cho hook "notify" mẫu trong config.jsonc
# ORCH_WEBHOOK_URL=
