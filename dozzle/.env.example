# =============================================================================
# dozzle/.env.example — Dozzle Docker log viewer
# =============================================================================
#
# Docs:
#   - https://dozzle.dev/
#   - https://hub.docker.com/r/amir20/dozzle
#
# Profiles: dozzle | full
# =============================================================================

# DOMAIN
#   Default DOZZLE_HOSTS = http://dozzle.${DOMAIN}, http://logs.${DOMAIN}
DOMAIN=example.com

# DOZZLE_HOSTS
#   Caddy site addresses. Use http:// because TLS terminates at Cloudflare/Tailscale.
#   Protects with caddy.import: tinyauth_forwarder * in dozzle/dozzle.yml.
DOZZLE_HOSTS=http://dozzle.example.com, http://logs.example.com
