# =============================================================================
# tailscale/.env.example — biến môi trường container Tailscale chính thức
# =============================================================================
#
# Mục đích: đầy đủ TS_* (Docker image tailscale/tailscale). Stack bật bằng
# profile: docker compose --profile tailscale up -d
#
# Tài liệu chính:
#   - Docker params: https://tailscale.com/docs/features/containers/docker/docker-params
#   - Containers overview: https://tailscale.com/docs/features/containers/docker
#   - Auth keys: https://tailscale.com/docs/features/access-control/auth-keys
#   - OAuth clients: https://tailscale.com/docs/features/oauth-clients
#   - Serve / Funnel: https://tailscale.com/docs/features/tailscale-serve
#   - Userspace networking: https://tailscale.com/docs/concepts/userspace-networking
#   - Image: https://hub.docker.com/r/tailscale/tailscale
#
# Cách lấy TS_CLIENT_ID / TS_CLIENT_SECRET:
#   1. https://login.tailscale.com/admin/settings/oauth
#   2. Generate OAuth client
#   3. Chọn scopes cần cho init:
#        policy_file:read, policy_file:write
#        networking_settings:read, networking_settings:write
#   4. Trust credentials này cũng có thể dùng để join machine vào tailnet.
#   5. Dán vào root .env; chạy init dry-run trước.
#
# Trong compose (tailscale/tailscale.yml) đang wire rõ:
#   TS_STATE_DIR, TS_USERSPACE, TS_EXTRA_ARGS, TS_SERVE_CONFIG, TS_HOSTNAME
# Optional TS_* khác đi qua env_file chỉ khi bạn set giá trị thật.
# Serve: tailscale/serve.json → proxy HTTPS riêng từng service, không qua Tinyauth.
#
# Profiles: tailscale | full  (KHÔNG nằm trong core)
#   COMPOSE_PROFILES=full
#   COMPOSE_PROFILES=core,tailscale
# =============================================================================

# -----------------------------------------------------------------------------
# Profiles (root .env)
# -----------------------------------------------------------------------------
# COMPOSE_PROFILES=full
# COMPOSE_PROFILES=core,tailscale

# -----------------------------------------------------------------------------
# Xác thực (chọn MỘT phương thức — không trộn mâu thuẫn)
# -----------------------------------------------------------------------------

# TS_CLIENT_ID / TS_CLIENT_SECRET
#   Công dụng:
#     1. tailscale/scripts/init.mjs gọi Tailscale API.
#     2. Docker image có thể dùng để join machine vào tailnet.
#   Có thể dùng file: prefix `file:/path/to/secret`
TS_CLIENT_ID=
TS_CLIENT_SECRET=

# TS_TAILNET
#   Công dụng: domain MagicDNS tailnet, ví dụ tail21ba49.ts.net.
#   Init dùng để render host private dạng files.${TS_TAILNET}.
TS_TAILNET=example.ts.net

# TS_TAGS
#   Công dụng: tags cần có trong ACL tagOwners và advertise khi container join.
#   Format: tag:name,tag:other
#   Default khớp tailscale/acl.hujson và tailscale/acl.sample.hujson.
TS_TAGS=tag:container,tag:ci

# TS_TAG_OWNERS
#   Công dụng: owners cho tagOwners mới tạo khi init merge ACL.
#   Lưu ý: init chỉ thêm owner cho tag mới; tagOwners đã có trong sample được giữ nguyên.
#   Default nếu không set: autogroup:admin
# TS_TAG_OWNERS=autogroup:admin

# TS_ACL_JSON_PATH
#   Công dụng: file ACL output được render từ sample + env, rồi upload lên remote Tailscale.
#   Default: tailscale/acl.hujson
TS_ACL_JSON_PATH=tailscale/acl.hujson

# TS_ACL_SAMPLE_PATH
#   Công dụng: file mẫu ACL đầu vào. Init merge TS_TAGS/TS_TAG_OWNERS vào sample này.
#   Default: tailscale/acl.sample.hujson
TS_ACL_SAMPLE_PATH=tailscale/acl.sample.hujson

# TS_SERVE_JSON_PATH
#   Công dụng: file output cho init render Serve config.
#   Default: tailscale/serve.json
# TS_SERVE_JSON_PATH=tailscale/serve.json

# TS_ID_TOKEN / TS_AUDIENCE
#   Công dụng: Workload identity federation (GHA/GCP/AWS… + TS_CLIENT_ID).
#   Không dùng cùng TS_CLIENT_SECRET.
#   Docs: https://tailscale.com/docs/features/workload-identity-federation
# TS_ID_TOKEN=
# TS_AUDIENCE=

# TS_AUTH_ONCE  [true|false]
#   Công dụng:
#     false — (mặc định) cố login mỗi lần start.
#     true  — Chỉ login nếu chưa authenticated (khi đã persist TS_STATE_DIR).
# TS_AUTH_ONCE=true

# -----------------------------------------------------------------------------
# Danh tính node & state
# -----------------------------------------------------------------------------

# TS_HOSTNAME
#   Công dụng: Hostname trên tailnet (MagicDNS). Không set → tên random Docker.
#   Ví dụ: proxy-stack → truy cập proxy-stack.<tailnet>.ts.net
TS_HOSTNAME=proxy-stack

# TS_STATE_DIR
#   Công dụng: Thư mục state tailscaled. Bắt buộc volume để giữ identity.
#   Không persist → mỗi restart = node mới trên admin console.
#   Compose: /var/lib/tailscale + volume tailscale-state
TS_STATE_DIR=/var/lib/tailscale

# TS_SOCKET
#   Công dụng: Path LocalAPI socket. Mặc định /var/run/tailscale/tailscaled.sock
# TS_SOCKET=

# TS_KUBE_SECRET
#   Công dụng: Tên K8s secret lưu state (chỉ Kubernetes). Compose thường bỏ.
# TS_KUBE_SECRET=

# -----------------------------------------------------------------------------
# Networking mode
# -----------------------------------------------------------------------------

# TS_USERSPACE  [true|false]
#   Công dụng:
#     true  — Userspace networking (mặc định image). Chạy mọi nơi, không cần
#             /dev/net/tun + NET_ADMIN. Hiệu năng thấp hơn một chút.
#             Khuyến nghị stack này / CI.
#     false — Kernel TUN. Nhanh hơn; cần:
#               devices: /dev/net/tun
#               cap_add: NET_ADMIN, NET_RAW (tuỳ setup)
#   Docs: userspace-networking
TS_USERSPACE=true

# TS_ACCEPT_DNS  [true|false]
#   Công dụng:
#     (không set/false) — Dùng DNS Docker mặc định trong container.
#     true — Nhận DNS/MagicDNS từ admin console tailnet.
#   Stack hiện truyền --accept-dns=false qua TS_EXTRA_ARGS.
# TS_ACCEPT_DNS=false

# TS_ROUTES
#   Công dụng: Advertise subnet routes (CIDR phẩy), ví dụ 192.168.1.0/24.
#   Tương đương: tailscale set --advertise-routes=
#   Cần approve routes trên admin console.
# TS_ROUTES=

# TS_DEST_IP
#   Công dụng: Proxy mọi traffic inbound Tailscale tới IP này.
# TS_DEST_IP=

# TS_TAILNET_TARGET_IP / TS_TAILNET_TARGET_FQDN
#   Công dụng: Egress proxy (non-tailscale → node trong tailnet).
#   Không tương thích TS_USERSPACE=true. Không dùng đồng thời IP và FQDN.
# TS_TAILNET_TARGET_IP=
# TS_TAILNET_TARGET_FQDN=

# TS_SOCKS5_SERVER
#   Công dụng: Listen SOCKS5 proxy (userspace), ví dụ :1055
# TS_SOCKS5_SERVER=

# TS_OUTBOUND_HTTP_PROXY_LISTEN
#   Công dụng: Listen HTTP proxy outbound, ví dụ :8080
# TS_OUTBOUND_HTTP_PROXY_LISTEN=

# -----------------------------------------------------------------------------
# Serve / Funnel
# -----------------------------------------------------------------------------

# TS_SERVE_CONFIG
#   Công dụng: Path file JSON cấu hình Serve/Funnel trong container.
#   Export mẫu: tailscale serve status --json
#   Stack: /config/serve.json (mount từ tailscale/serve.json)
#   Proxy HTTPS tailnet → từng service trực tiếp theo tailscale/scripts/init.jsonc
TS_SERVE_CONFIG=/config/serve.json

# TS_EXPERIMENTAL_SERVICE_AUTO_ADVERTISEMENT  [true|false]
#   Công dụng (v1.96+): Tự advertise Tailscale Services từ Serve config.
#     true  — Mặc định mới: auto advertise khi start.
#     false — Tắt auto (hành vi cũ / tự quản lý).
# TS_EXPERIMENTAL_SERVICE_AUTO_ADVERTISEMENT=true

# -----------------------------------------------------------------------------
# Publish app qua tailnet — tailscale/scripts/publish.mjs (Cách A + B song song)
# Chi tiết: docs/tailscale-publish.md
# -----------------------------------------------------------------------------

# TS_PUBLISH_MODE  [off | serve | services | both]   (default: off)
#   Công tắc chính, chọn CÁCH publish app ra tailnet:
#     off      — Không publish app (chỉ giữ TCP 443 HTTPS + 2222 SSH sync). An toàn.
#     serve    — Cách A: Tailscale Serve Web (serve.json Web{}). Proxy nội bộ chạy
#                nhưng KHÔNG tạo MagicDNS record riêng cho subdomain.
#     services — Cách B: Tailscale Services (svc:<name>). Tạo DNS name THẬT
#                https://<name>.<tailnet>/, cần autoApprovers.services (auto).
#     both     — Bật cả A và B song song.
#   Bật/tắt độc lập; đổi mode → chạy lại `npm run ts-init` rồi `npm run ts-publish`.
# TS_PUBLISH_MODE=off

# TS_SERVE_STYLE  [subdomain | path]   (default: subdomain) — chỉ áp dụng Cách A
#   subdomain — mỗi app 1 host ảo:   https://auth.<tailnet>, https://files.<tailnet>...
#   path      — gộp trên host của node: https://<TS_HOSTNAME>.<tailnet>/auth, /files...
# TS_SERVE_STYLE=subdomain

# TS_SERVICES_AUTOAPPROVE  [1|0]   (default: 1) — chỉ áp dụng Cách B
#   1 — init.mjs ghi autoApprovers.services vào ACL.
#       publish.mjs tự tạo VIP services + approve host qua API → không kẹt "pending approval".
#   0 — Không ghi; bạn phải duyệt thủ công trong admin console.
# TS_SERVICES_AUTOAPPROVE=1

# TS_HOSTNAME  (tùy chọn, default: auto-detect từ Tailscale API)
#   Hostname của node trên tailnet, dùng cho Cách A style=path.
#   KHÔNG CẦN set thủ công — init.mjs và publish.mjs tự detect từ Tailscale API.
#   Chỉ set nếu muốn override (vd CI hostname cố định).
# TS_HOSTNAME=proxy-stack

# -----------------------------------------------------------------------------
# Metrics / health (Tailscale ≥ 1.78)
# -----------------------------------------------------------------------------

# TS_ENABLE_HEALTH_CHECK  [true|false]
#   Công dụng: true → endpoint /healthz (200 nếu có tailnet IP, else 503).
# TS_ENABLE_HEALTH_CHECK=false

# TS_ENABLE_METRICS  [true|false]
#   Công dụng: true → endpoint /metrics (Prometheus-style client metrics).
# TS_ENABLE_METRICS=false

# TS_LOCAL_ADDR_PORT
#   Công dụng: [addr]:port cho health/metrics. Mặc định [::]:9002
# TS_LOCAL_ADDR_PORT=[::]:9002

# -----------------------------------------------------------------------------
# Extra CLI flags
# -----------------------------------------------------------------------------

# TS_EXTRA_ARGS
#   Công dụng: Flags thêm cho `tailscale up` / set.
#   Ví dụ thường dùng:
#     --accept-dns=false     Không nhận DNS tailnet (stack mặc định)
#     --advertise-tags=tag:container,tag:ci  Bắt buộc khi auth bằng OAuth client
#     --advertise-exit-node  Quảng bá exit node (cần ACL + approve)
#     --ssh                  Bật Tailscale SSH
#     --accept-routes        Nhận subnet route từ node khác
#   Nhiều flag: cách nhau bằng space trong một string.
TS_EXTRA_ARGS=--accept-dns=false

# TS_TAILSCALED_EXTRA_ARGS
#   Công dụng: Flags cho daemon tailscaled (ví dụ --verbose=2).
# TS_TAILSCALED_EXTRA_ARGS=

# -----------------------------------------------------------------------------
# Init script
# -----------------------------------------------------------------------------

# Dry-run: không gọi API, không ghi file
#   node tailscale/scripts/init.mjs --env .env --dry-run
#
# Apply:
#   node tailscale/scripts/init.mjs --env .env
#
# Luồng ACL:
#   .env + tailscale/acl.sample.hujson -> tailscale/acl.hujson -> remote Tailscale ACL
#
# Config route riêng từng service; aliases dùng "names" trong init.jsonc:
#   tailscale/scripts/init.jsonc

# -----------------------------------------------------------------------------
# serve.json (tham chiếu — file JSON, không phải env)
# -----------------------------------------------------------------------------
# {
#   "TCP": { "443": { "HTTPS": true } },
#   "Web": {
#     "files.${TS_TAILNET}:443": {
#       "Handlers": { "/": { "Proxy": "http://files:80" } }
#     }
#   }
# }
