# =============================================================================
# litestream/.env.example — biến môi trường Litestream indexed
# =============================================================================
#
# Mục đích: cấu hình restore + replicate SQLite DB lên S3-compatible storage
# (Supabase Storage S3, Cloudflare R2, MinIO, AWS S3...). Stack dùng một service
# Litestream chung cho nhiều app; mỗi DB/app là một block LITESTREAM_<index>_*.
#
# Tài liệu chính:
#   - Litestream: https://litestream.io/
#   - Config reference: https://litestream.io/reference/config/
#   - S3 replica: https://litestream.io/reference/config/#s3-replica
#   - Supabase S3 compatibility: https://supabase.com/docs/guides/storage/s3/authentication
#   - Image: https://hub.docker.com/r/litestream/litestream
#
# Rule bắt buộc trong repo:
#   1. Env luôn indexed: LITESTREAM_<index>_<KEY>
#   2. Mỗi index = một SQLite DB/service.
#   3. Data local dùng Litestream phải nằm dưới:
#        ${DOCKER_VOLUME_DATA}/litestream/<service>/
#   4. SERVICE là slug lowercase, nên trùng folder/service compose.
#   5. PATH trong container nên khớp /data/<service>/<file>.db
#   6. Không set block rỗng. Chỉ copy block có giá trị thật vào root .env.
#
# Trong compose/scripts đang wire:
#   - litestream/litestream.yml mount:
#       ${DOCKER_VOLUME_DATA:-./ci-data}/litestream:/data
#       ${DOCKER_VOLUME_RUNTIME:-./ci-runtime}/litestream:/etc/litestream:ro
#   - scripts/up.mjs và scripts/runners/start-stack.mjs chạy:
#       litestream/scripts/generate-config.mjs
#       litestream/scripts/restore.mjs
#     trước khi docker compose up.
#   - Nếu có LITESTREAM_<index>_SERVICE, helper auto-enable profile litestream.
#   - Nếu remote S3 chưa có backup: restore bỏ qua, app tự tạo DB, replicate sau.
#
# Profiles:
#   litestream được bật tự động bởi helpers khi có config.
#   Chạy tay:
#     docker compose --profile litestream up -d litestream
# =============================================================================

# -----------------------------------------------------------------------------
# Stack volume roots (root .env)
# -----------------------------------------------------------------------------

# DOCKER_VOLUME_DATA
#   Công dụng: root chứa app data persistent.
#   Litestream-managed data bắt buộc nằm dưới:
#     ${DOCKER_VOLUME_DATA}/litestream/<service>/
#   Default root .env.example: ./ci-data
# DOCKER_VOLUME_DATA=./ci-data

# DOCKER_VOLUME_RUNTIME
#   Công dụng: root chứa generated runtime config.
#   Litestream config generated tại:
#     ${DOCKER_VOLUME_RUNTIME}/litestream/litestream.yml
#   Default root .env.example: ./ci-runtime
# DOCKER_VOLUME_RUNTIME=./ci-runtime

# -----------------------------------------------------------------------------
# Image
# -----------------------------------------------------------------------------

# LITESTREAM_IMAGE
#   Công dụng: image Litestream dùng cho service replicate và script restore.
#   Chỉ đổi khi cần pin version khác.
#   Default trong compose/scripts: litestream/litestream:0.3.13
# LITESTREAM_IMAGE=litestream/litestream:0.3.13

# -----------------------------------------------------------------------------
# Block 0 — Tinyauth SQLite DB
# -----------------------------------------------------------------------------

# LITESTREAM_0_SERVICE
#   Công dụng: slug service/app cho block này.
#   Giá trị này quyết định thư mục local theo rule:
#     ${DOCKER_VOLUME_DATA}/litestream/tinyauth/
#   Nên trùng folder/service compose: tinyauth/
LITESTREAM_0_SERVICE=tinyauth

# LITESTREAM_0_PATH
#   Công dụng: đường dẫn SQLite DB bên trong container Litestream.
#   Vì DOCKER_VOLUME_DATA/litestream được mount vào /data, path này map về:
#     ./ci-data/litestream/tinyauth/tinyauth.db
#   Phải khớp app config. Với Tinyauth:
#     TINYAUTH_DATABASE_PATH=/data/tinyauth/tinyauth.db
LITESTREAM_0_PATH=/data/tinyauth/tinyauth.db

# LITESTREAM_0_URL
#   Công dụng: remote replica URL. Dùng dạng s3://bucket/key.
#   Đây là nơi restore pull xuống trước khi app start, và replicate push lên sau.
#   Ví dụ:
#     s3://my-bucket/proxy-stack/tinyauth.db
# LITESTREAM_0_URL=s3://bucket/path/tinyauth.db

# LITESTREAM_0_BUCKET / LITESTREAM_0_KEY
#   Công dụng: cách viết thay thế cho LITESTREAM_0_URL.
#   Nếu URL không set, script ghép:
#     s3://<BUCKET>/<KEY>
#   BUCKET chỉ là tên bucket, KHÔNG chứa folder/path.
#     Đúng: LITESTREAM_0_BUCKET=hoahien7281
#     Sai:  LITESTREAM_0_BUCKET=hoahien7281/data-tiny-auth
#   Folder/path đặt trong KEY:
#     LITESTREAM_0_KEY=data-tiny-auth/tinyauth.db
#   Nếu KEY không set, script tự dùng:
#     <SERVICE>/<db filename>
#   Với Tinyauth: tinyauth/tinyauth.db
LITESTREAM_0_BUCKET=bucket
# LITESTREAM_0_KEY=data-tiny-auth/tinyauth.db

# LITESTREAM_0_ACCESS_KEY_ID
#   Công dụng: S3 access key id.
#   Với Supabase: tạo S3 access key trong dashboard Storage/S3.
#   Secret — chỉ đặt trong root .env hoặc GitHub secret ENV_FILE.
LITESTREAM_0_ACCESS_KEY_ID=

# LITESTREAM_0_SECRET_ACCESS_KEY
#   Công dụng: S3 secret access key.
#   Secret — không commit giá trị thật.
LITESTREAM_0_SECRET_ACCESS_KEY=

# LITESTREAM_0_ENDPOINT
#   Công dụng: endpoint S3-compatible.
#   Supabase thường là:
#     https://<project-ref>.supabase.co/storage/v1/s3
#   AWS S3 có thể bỏ trống để dùng endpoint mặc định theo region.
LITESTREAM_0_ENDPOINT=https://project-ref.supabase.co/storage/v1/s3

# LITESTREAM_0_REGION
#   Công dụng: region S3.
#   Supabase thường dùng auto.
#   AWS S3 dùng region thật, ví dụ us-east-1.
LITESTREAM_0_REGION=auto

# LITESTREAM_0_FORCE_PATH_STYLE  [true|false]
#   Công dụng: dùng path-style URL thay vì virtual-hosted-style.
#     true  — thường cần cho Supabase/R2/MinIO/S3-compatible.
#     false — thường OK cho AWS S3 chuẩn.
LITESTREAM_0_FORCE_PATH_STYLE=true

# -----------------------------------------------------------------------------
# Block 1+ — app khác
# -----------------------------------------------------------------------------

# Tăng index cho DB/service tiếp theo. Không cần sửa script.
#
# LITESTREAM_1_SERVICE=myapp
# LITESTREAM_1_PATH=/data/myapp/app.db
# LITESTREAM_1_URL=s3://bucket/path/myapp.db
# LITESTREAM_1_ACCESS_KEY_ID=
# LITESTREAM_1_SECRET_ACCESS_KEY=
# LITESTREAM_1_ENDPOINT=https://project-ref.supabase.co/storage/v1/s3
# LITESTREAM_1_REGION=auto
# LITESTREAM_1_FORCE_PATH_STYLE=true

# -----------------------------------------------------------------------------
# Helper scripts
# -----------------------------------------------------------------------------

# Generate config only:
#   node litestream/scripts/generate-config.mjs --env .env --dry-run
#   node litestream/scripts/generate-config.mjs --env .env
#
# Restore only:
#   node litestream/scripts/restore.mjs --env .env --dry-run
#   node litestream/scripts/restore.mjs --env .env
#
# Normal startup:
#   node scripts/up.mjs
#   make up
#   npm run up
#
# CI startup:
#   scripts/runners/start-stack.mjs runs generate + restore before compose up.

# -----------------------------------------------------------------------------
# Generated config shape (tham chiếu — file YAML, không phải env)
# -----------------------------------------------------------------------------
# dbs:
#   - path: "/data/tinyauth/tinyauth.db"
#     replicas:
#       - url: "s3://bucket/path/tinyauth.db"
#         endpoint: "https://project-ref.supabase.co/storage/v1/s3"
#         region: "auto"
#         access-key-id: "..."
#         secret-access-key: "..."
#         force-path-style: true
