{
  // Remotely-managed named tunnel ingress. "hostname" không có dấu chấm sẽ
  // tự ghép .{DOMAIN}. Rule SSH dùng sshd trên CI runner qua host-gateway.
  "ingress": [
    { "hostname": "auth", "service": "http://caddy:80" },
    { "hostname": "files", "service": "http://caddy:80" },
    { "hostname": "ttyd", "service": "http://caddy:80" },
    { "hostname": "webssh", "service": "http://caddy:80" },
    { "hostname": "whoami", "service": "http://caddy:80" },
    { "hostname": "dozzle", "service": "http://caddy:80" },
    { "hostname": "logs", "service": "http://caddy:80" },
    { "hostname": "ssh", "service": "ssh://host.docker.internal:22" }
  ],
  "catch_all": "http_status:404"
}
