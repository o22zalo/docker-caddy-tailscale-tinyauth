# Nodesync zero-touch CI catalog. Copy keys cần dùng vào root .env/ENV_FILE.
# Mặc định không sync và không chạy SSH.
SSH_ENABLE=0
NODESYNC_SYNC_PATHS=

# Bật ví dụ:
# SSH_ENABLE=1
# NODESYNC_SYNC_PATHS=ci-data,uploads
# SSH_CHANNEL_TAILSCALE_ENABLE=1
# SSH_CHANNEL_CLOUDFLARE_ENABLE=1
# SSH_CHANNEL_HYBRID_ENABLE=1

# Keypair chung cho các runner; bootstrap tự cài public key vào host sshd.
# Private/public key không được commit. B64 dùng output `base64 -w0`.
# SSH_1_PRIVATE_KEY_B64=1
# SSH_1_PRIVATE_KEY=<base64-private-ed25519-key>
# SSH_1_PUBLIC_KEY_B64=1
# SSH_1_PUBLIC_KEY=<base64-public-ed25519-key>

# Cloudflare Access Service Auth, chỉ cần nếu ssh.<DOMAIN> gắn Access app.
# TUNNEL_SERVICE_TOKEN_ID=
# TUNNEL_SERVICE_TOKEN_SECRET=

# Không cần cấu hình peer, hostname node01/node02, sync-on-start, password,
# ORCH_NODE_ID hoặc WHOAMI_NAME. RTDB discovery + setup-env tự xử lý.
