# =============================================================================
# nodesync/.env.example — Catalog biến môi trường cho sidecar nodesync
# =============================================================================
#
# Copy các dòng cần dùng sang .env gốc của repo (KHÔNG commit secret thật).
# nodesync chỉ hoạt động khi SSH_ENABLE=1 + profile nodesync/full.
#
# MỤC ĐÍCH: đồng bộ dữ liệu giữa các node qua SSH (chép file + chạy lệnh),
# kênh Tailscale → Cloudflare → Hybrid (cấu hình + fallback). node02 khi start
# sẽ: pull remote store → diff với node01 qua ssh → sync → mới start app.
#
# Tài liệu Tailscale liên quan (resolve DNS đúng cách trong userspace):
#   - https://tailscale.com/docs/reference/quad100
#   - https://tailscale.com/docs/features/magicdns
#   - https://tailscale.com/docs/concepts/userspace-networking
#   - https://tailscale.com/docs/features/tailscale-ssh
# =============================================================================

# ── Bật/tắt nodesync ─────────────────────────────────────────────────────────
# 0 = tắt (container idle, không mở sshd, không tạo user)
# 1 = bật (tạo user + sshd + hold-gate, sẵn sàng làm nguồn/đích sync)
# SSH_ENABLE=1
# Chỉ node02 (node nhận dữ liệu) bật pre-start sync; node01 để 0.
# NODESYNC_SYNC_ON_START=1

# Profile để compose lên service này:
# COMPOSE_PROFILES=full
# COMPOSE_PROFILES=core,nodesync

# ── Multi-user (tạo nhiều user theo index) ───────────────────────────────────
# Với mỗi index N (1,2,3...) khai báo user. USERNAME bắt buộc; còn lại tuỳ chọn.
#   SSH_<N>_USER          tên user (bắt buộc để tạo user index N)
#   SSH_<N>_PASS          mật khẩu (hoặc SSH_<N>_PASSWORD). Đặt _B64=1 nếu base64.
#   SSH_<N>_PUBLIC_KEY    public key → ghi vào authorized_keys
#   SSH_<N>_PRIVATE_KEY   private key → ghi vào ~/.ssh/id_ed25519 (để user này ssh đi)
#   SSH_<N>_PRIVILEGED    1 (mặc định) = sudo NOPASSWD:ALL (chạy MỌI lệnh); 0 = không
#   SSH_<N>_SHELL         shell (mặc định /bin/bash)
#   SSH_<N>_UID           uid cố định (tuỳ chọn)
#
# CỜ BASE64 (mask secret theo qui tắc repo `base64 -w0`):
#   SSH_<N>_PASS_B64=1 / SSH_<N>_PASSWORD_B64=1 / SSH_<N>_PRIVATE_KEY_B64=1 /
#   SSH_<N>_PUBLIC_KEY_B64=1
#   → giá trị tương ứng sẽ được giải mã base64 trước khi dùng.
#
# Tạo base64:  echo -n 'mật-khẩu' | base64 -w0     (Linux)
#
# Ví dụ 2 user:
# SSH_1_USER=sync
# SSH_1_PASS_B64=1
# SSH_1_PASS=c3luY3Bhc3M=          # base64 của "syncpass"
# SSH_1_PUBLIC_KEY=ssh-ed25519 AAAA... sync@ci
# SSH_1_PRIVATE_KEY_B64=1
# SSH_1_PRIVATE_KEY=<base64 của private key ed25519>
# SSH_1_PRIVILEGED=1
#
# SSH_2_USER=admin
# SSH_2_PASS_B64=1
# SSH_2_PASS=YWRtaW5wYXNz          # base64 của "adminpass"
# SSH_2_PRIVILEGED=1

# ── Kênh truyền + fallback (Tailscale → Cloudflare → Hybrid) ─────────────────
# Enable từng kênh. sync sẽ thử theo thứ tự channel_priority (config.jsonc),
# kênh nào tắt/lỗi thì fallback sang kênh kế tiếp.
# SSH_CHANNEL_TAILSCALE_ENABLE=1    # mặc định bật
# SSH_CHANNEL_CLOUDFLARE_ENABLE=0
# SSH_CHANNEL_HYBRID_ENABLE=0

# ── Thông tin peer node01 (để node02 kết nối) ────────────────────────────────
# Tailscale: hostname/alias của node01 trên tailnet (MagicDNS). resolve qua
#   `tailscale status --json` (đúng userspace + accept-dns=false).
# NODESYNC_PEER_TAILSCALE_HOST=proxy-stack-a
# Cloudflare: hostname cấu hình ingress SSH (cloudflared access ssh --hostname).
# NODESYNC_PEER_CLOUDFLARE_HOST=ssh-node01.example.com
# Hybrid / trực tiếp: IP hoặc host (fallback cuối / test cùng docker network).
# NODESYNC_PEER_HOST=node01
# NODESYNC_PEER_PORT=22
# NODESYNC_PEER_USER=sync           # user ssh sang node01 (mặc định user index 1)

# ── Đường dẫn dữ liệu cần đồng bộ (override config.jsonc) ────────────────────
# Mặc định: ci-data. KHÔNG sync toàn ci-runtime vì chứa Tailscale identity,
# Caddy state và SSH host keys riêng từng node.
# NODESYNC_SYNC_PATHS=ci-data
# NODESYNC_RETRY_AFTER_SECONDS=15    # 503 Retry-After khi node01 treo request

# SSH không publish ra host mặc định. Nếu cần direct-host test, tạo Compose
# override có `ports: ["2222:22"]`; không mở port trên môi trường công khai.

# ── Workspace mount (thường để mặc định) ─────────────────────────────────────
# SSH_WORKSPACE=/workspace
