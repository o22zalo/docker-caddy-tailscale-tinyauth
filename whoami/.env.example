# =============================================================================
# whoami/.env.example — demo upstream (traefik/whoami) + label Caddy
# =============================================================================
#
# Mục đích: biến stack dùng để route whoami qua Caddy; image whoami gần như
# không cần secret. Dùng chứng minh Internet → Tunnel → Caddy → app.
#
# Tài liệu:
#   - Image: https://hub.docker.com/r/traefik/whoami
#   - Repo: https://github.com/traefik/whoami
#   - Tinyauth + Caddy labels: https://tinyauth.app/docs/community/caddy/
#   - caddy-docker-proxy labels:
#     https://github.com/lucaslorentz/caddy-docker-proxy#labels-to-caddyfile-conversion
#
# Trong compose (whoami/whoami.yml):
#   WHOAMI_HOST / DOMAIN → label `caddy`
#   caddy.import: whoami_tinyauth_forwarder *  (auth bật bằng WHOAMI_TINYAUTH_ENABLED)
# CI (docker-compose.ci.yml): catch-all `:80`, public không login.
#
# Profiles: whoami | core | full  (COMPOSE_PROFILES ở root .env)
# =============================================================================

# -----------------------------------------------------------------------------
# Profiles (root .env)
# -----------------------------------------------------------------------------
# COMPOSE_PROFILES=core
# COMPOSE_PROFILES=whoami,caddy

# DOMAIN
#   Công dụng: Domain gốc; default WHOAMI_HOST = http://whoami.${DOMAIN}
DOMAIN=example.com

# WHOAMI_HOST
#   Công dụng: Site address Caddy cho whoami.
#   Dùng http:// khi TLS terminate tại Cloudflare Tunnel.
#   Phải khớp Public Hostname trên tunnel (Service URL http://caddy:80).
#
# Ví dụ giá trị:
#   http://whoami.example.com     — prod (Host-based routing)
#   :80                           — CI catch-all (set trong docker-compose.ci.yml)
WHOAMI_HOST=http://whoami.example.com

# WHOAMI_TINYAUTH_ENABLED
#   Công dụng: bật Tinyauth cho route whoami.
#   Default false: whoami public, không cần login.
#   Set true: Caddy chạy forward-auth qua tinyauth trước khi proxy vào whoami.
WHOAMI_TINYAUTH_ENABLED=false

# -----------------------------------------------------------------------------
# Image whoami — biến tùy chọn (upstream; hầu hết không cần)
# -----------------------------------------------------------------------------
# whoami chủ yếu là HTTP server tĩnh thông tin request.
# Một số fork/build hỗ trợ:
#
# WHOAMI_PORT_NUMBER / PORT
#   Công dụng: Port listen trong container. Image traefik/whoami mặc định 80.
#   Stack + Caddy label upstreams 80 — không đổi trừ khi bạn sửa label.
# WHOAMI_PORT_NUMBER=80
#
# WHOAMI_NAME
#   Công dụng (nếu hỗ trợ): Tên hiển thị trong response body.
# WHOAMI_NAME=whoami

# -----------------------------------------------------------------------------
# Labels Caddy (tham chiếu — cấu hình trong whoami.yml, không phải env process)
# -----------------------------------------------------------------------------
# caddy: ${WHOAMI_HOST}
# caddy.reverse_proxy: "{{upstreams 80}}"
# caddy.import: whoami_tinyauth_forwarder *
#
# WHOAMI_TINYAUTH_ENABLED=false → public không cần login.
