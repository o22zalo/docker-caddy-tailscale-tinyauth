# =============================================================================
# rclone/.env.example — biến môi trường Rclone indexed
# =============================================================================
#
# Mục đích: pull file/folder từ remote về trước khi app start, rồi định kỳ push
# thay đổi local lên remote. Mỗi block RCLONE_<index>_* là một job độc lập.
#
# Tài liệu:
#   - Rclone: https://rclone.org/
#   - Config file: https://rclone.org/docs/#config-config-file
#   - Copy: https://rclone.org/commands/rclone_copy/
#   - Bisync: https://rclone.org/bisync/
#
# Rule:
#   1. Env luôn indexed: RCLONE_<index>_<KEY>
#   2. RCLONE_<index>_NAME là slug job và tạo container name:
#        rclone-<index>-<name>
#      Ví dụ RCLONE_0_NAME=tinyauth-db -> rclone-0-tinyauth-db
#   3. Rclone mount cố định các root:
#        workspace root           -> /workspace
#        ${DOCKER_VOLUME_DATA}    -> /data
#        ${DOCKER_VOLUME_RUNTIME} -> /runtime
#      RCLONE_<index>_LOCAL chấp nhận:
#        /data/rclone/<name>
#        /runtime/<service>
#        /workspace/ci-runtime/<service>
#        ./ci-runtime/<service>
#        ${DOCKER_VOLUME_RUNTIME}/<service>
#        {DOCKER_VOLUME_RUNTIME}/<service>
#   4. TAGS dùng để chỉ chạy một nhóm nghiệp vụ:
#        RCLONE_TAGS=tailscale node rclone/scripts/pull.mjs --env .env
#        node rclone/scripts/pull.mjs --env .env --tags tailscale
#   5. CONFIG_BASE64 ưu tiên hơn CONFIG_RAW.
#   6. Không copy block rỗng vào root .env.
# =============================================================================

# -----------------------------------------------------------------------------
# Mount map trong rclone/rclone.yml
# -----------------------------------------------------------------------------
#
# 1. Workspace root:
#      ..:/workspace
#    Dùng khi muốn trỏ đúng path repo bằng đường dẫn tương đối:
#      RCLONE_0_LOCAL=./ci-runtime/tailscale
#      RCLONE_0_LOCAL=/workspace/ci-runtime/tailscale
#
# 2. Data root:
#      ${DOCKER_VOLUME_DATA_ABS:-../ci-data}:/data
#    DOCKER_VOLUME_DATA=./ci-data thì các path này tương đương:
#      RCLONE_0_LOCAL=${DOCKER_VOLUME_DATA}/rclone/uploads
#      RCLONE_0_LOCAL={DOCKER_VOLUME_DATA}/rclone/uploads
#      RCLONE_0_LOCAL=/data/rclone/uploads
#      -> ./ci-data/rclone/uploads
#
# 3. Runtime root:
#      ${DOCKER_VOLUME_RUNTIME_ABS:-../ci-runtime}:/runtime
#    DOCKER_VOLUME_RUNTIME=./ci-runtime thì các path này tương đương:
#      RCLONE_0_LOCAL=${DOCKER_VOLUME_RUNTIME}/tailscale
#      RCLONE_0_LOCAL={DOCKER_VOLUME_RUNTIME}/tailscale
#      RCLONE_0_LOCAL=/runtime/tailscale
#      -> ./ci-runtime/tailscale
#
# 4. Rclone generated config:
#      ${DOCKER_VOLUME_RUNTIME_ABS:-../ci-runtime}/rclone:/config/rclone
#    Script ghi config runtime tại:
#      ./ci-runtime/rclone/<index>-<name>.conf
#    Container dùng:
#      /config/rclone/<index>-<name>.conf
#    Thư mục này là config nội bộ rclone, không phải data nghiệp vụ cần sync.
#

# RCLONE_0_NAME
#   Tên job, dùng cho thư mục local và container name.
RCLONE_0_NAME=tinyauth-db

# RCLONE_0_TAGS
#   Nhãn nghiệp vụ để lọc khi chạy pull/sync.
#   Nhiều tag cách nhau bằng dấu phẩy hoặc khoảng trắng.
RCLONE_0_TAGS=app,data

# RCLONE_0_TYPE [file|dir]
#   file: sync một file riêng lẻ.
#   dir: sync cả thư mục.
RCLONE_0_TYPE=file

# RCLONE_0_LOCAL
#   Đường dẫn trong container rclone.
#   Map về workspace:
#     ${DOCKER_VOLUME_DATA}/rclone/tinyauth-db/tinyauth.db
#     -> ./ci-data/rclone/tinyauth-db/tinyauth.db
#   Các dạng hợp lệ khác:
#     /data/rclone/tinyauth-db/tinyauth.db
#     /runtime/tailscale
#     ./ci-runtime/tailscale
#     ${DOCKER_VOLUME_RUNTIME}/tailscale
RCLONE_0_LOCAL=${DOCKER_VOLUME_DATA}/rclone/tinyauth-db/tinyauth.db

# RCLONE_0_REMOTE
#   Remote rclone. Có thể là file hoặc thư mục tùy TYPE.
#   Remote name phải tồn tại trong config raw/base64 hoặc config mặc định.
RCLONE_0_REMOTE=remote:proxy-stack/tinyauth.db

# RCLONE_0_INTERVAL
#   Số giây giữa các lần push local -> remote sau khi container chạy.
#   Default trong rclone/scripts/rclone.jsonc: 300.
RCLONE_0_INTERVAL=300

# RCLONE_0_DIRECTION [copy|bisync]
#   copy: push local -> remote, đơn giản và ít conflict.
#   bisync: hai chiều; chỉ bật khi hiểu rclone bisync conflict rules.
# RCLONE_0_DIRECTION=copy

# RCLONE_0_CONFIG_BASE64
#   Base64 nội dung rclone.conf. Ưu tiên hơn CONFIG_RAW.
#   Tạo:
#     base64 -w0 rclone.conf
# RCLONE_0_CONFIG_BASE64=

# RCLONE_0_CONFIG_RAW
#   Nội dung rclone.conf raw. Dùng khi ENV_FILE/GitHub secret giữ newline ổn.
#   Ví dụ:
#     [remote]
#     type = s3
#     provider = Cloudflare
#     access_key_id = ...
#     secret_access_key = ...
#     endpoint = https://...
# RCLONE_0_CONFIG_RAW=

# Nhiều file riêng lẻ:
# RCLONE_1_NAME=app-config
# RCLONE_1_TAGS=app,config
# RCLONE_1_TYPE=file
# RCLONE_1_LOCAL=${DOCKER_VOLUME_DATA}/rclone/app-config/config.json
# RCLONE_1_REMOTE=remote:proxy-stack/config.json
# RCLONE_1_INTERVAL=120
# RCLONE_1_CONFIG_BASE64=...

# Cả thư mục:
# RCLONE_2_NAME=uploads
# RCLONE_2_TAGS=uploads,data
# RCLONE_2_TYPE=dir
# RCLONE_2_LOCAL=${DOCKER_VOLUME_DATA}/rclone/uploads
# RCLONE_2_REMOTE=remote:proxy-stack/uploads
# RCLONE_2_INTERVAL=300
# RCLONE_2_CONFIG_BASE64=...

# Dry-run:
#   node rclone/scripts/pull.mjs --env .env --dry-run
#   node rclone/scripts/pull.mjs --env .env --tags tailscale --dry-run
#
# Normal startup:
#   node scripts/up.mjs
