{
  // Max time for opencode agent analysis in CI.
  "timeout_ms": 600000,

  // Services expected in this stack.
  "services": ["caddy", "tinyauth", "whoami", "cloudflared", "tailscale", "litestream", "rclone", "dozzle", "filebrowser", "webssh"],

  // Source/config files opencode must inspect when correlating logs to fixes.
  "code_files": [
    "docker-compose.yml",
    "docker-compose.ci.yml",
    "networks/networks.yml",
    "caddy/caddy.yml",
    "litestream/litestream.yml",
    "litestream/scripts/generate-config.mjs",
    "litestream/scripts/restore.mjs",
    "rclone/rclone.yml",
    "rclone/Dockerfile",
    "rclone/scripts/pull.mjs",
    "rclone/scripts/sync-loop.mjs",
    "tinyauth/tinyauth.yml",
    "whoami/whoami.yml",
    "dozzle/dozzle.yml",
    "filebrowser/filebrowser.yml",
    "webssh/webssh.yml",
    "cloudflare/cloudflare.yml",
    "tailscale/tailscale.yml",
    ".github/workflows/test.yml",
    "scripts/runners/setup-env.mjs",
    "scripts/runners/start-stack.mjs",
    "scripts/runners/collect-logs.mjs",
    "scripts/wait-and-test.mjs"
  ]
}
