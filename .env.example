# =============================================================================
# Root .env.example — file env THỰC TẾ Docker Compose đọc (project root)
# =============================================================================
#
#   cp .env.example .env
#   docker compose up -d
#
# GitHub: secret ENV_FILE = toàn bộ nội dung .env
#
# Catalog đầy đủ theo service:
#   cloudflare/.env.example | caddy/.env.example | litestream/.env.example | rclone/.env.example | tinyauth/.env.example
#   whoami/.env.example | dozzle/.env.example | filebrowser/.env.example
#   webssh/.env.example | tailscale/.env.example | networks/.env.example | orchestrator/.env.example
# =============================================================================

# -----------------------------------------------------------------------------
# COMPOSE_PROFILES — bật/tắt service (Compose đọc biến này tự động)
# Docs: https://docs.docker.com/compose/how-tos/profiles/
#
# Profile riêng (từng service):
#   caddy | litestream | rclone | tinyauth | whoami | cloudflare | tailscale | dozzle | filebrowser | webssh | orchestrator
#
# Profile nhóm:
#   core — caddy + tinyauth + whoami + cloudflare  (public stack, khuyến nghị)
#   full — core + tailscale + admin tools (dozzle + filebrowser + webssh)
#
# Service thuộc profile nào (OR — bật nếu BẤT KỲ profile khớp):
#   caddy       → caddy, core, full
#   litestream  → litestream
#   rclone      → rclone
#   tinyauth    → tinyauth, core, full
#   whoami      → whoami, core, full
#   cloudflared → cloudflare, core, full
#   tailscale   → tailscale, full
#   dozzle      → dozzle, full
#   filebrowser → filebrowser, full
#   webssh      → webssh, full
#
# Ví dụ:
#   COMPOSE_PROFILES=core        # litestream/rclone auto-added by helpers if configured
#   COMPOSE_PROFILES=full        # do not list litestream/rclone manually unless using docker compose directly
#   COMPOSE_PROFILES=caddy,whoami
#   COMPOSE_PROFILES=core,tailscale
#
# CLI (ghi đè / bổ sung):
#   docker compose --profile tailscale up -d
#   docker compose --profile caddy --profile whoami up -d
#
# Helpers (`node scripts/up.mjs`, CI start-stack) auto-enable:
#   litestream — when any LITESTREAM_<index>_SERVICE exists
#   rclone     — when any RCLONE_<index>_NAME exists
# Plain `docker compose up` cannot infer this; use helpers for fallback profiles.
# -----------------------------------------------------------------------------
COMPOSE_PROFILES=core

# --- Runtime/data bind mounts ---
# Runtime: service state, generated config, logs, tmux/Tailscale/Caddy runtime files.
DOCKER_VOLUME_RUNTIME=./ci-runtime
# Data: app data intended to persist as more apps are added.
DOCKER_VOLUME_DATA=./ci-data

# --- Litestream (SQLite restore/replication to S3-compatible storage) ---
# All Litestream-managed data lives under ${DOCKER_VOLUME_DATA}/litestream/<service>/.
# No LITESTREAM_<index>_* block means restore/replication is skipped.
# LITESTREAM_IMAGE=litestream/litestream:0.3.13
# LITESTREAM_0_SERVICE=tinyauth
# LITESTREAM_0_PATH=/data/tinyauth/tinyauth.db
# LITESTREAM_0_BUCKET=bucket
# LITESTREAM_0_KEY=data-tiny-auth/tinyauth.db
# LITESTREAM_0_ACCESS_KEY_ID=
# LITESTREAM_0_SECRET_ACCESS_KEY=
# LITESTREAM_0_ENDPOINT=https://project-ref.supabase.co/storage/v1/s3
# LITESTREAM_0_REGION=auto
# LITESTREAM_0_FORCE_PATH_STYLE=true

# --- Rclone (file/folder pull before startup + periodic push to remote) ---
# Rclone mounts workspace root as /workspace, DOCKER_VOLUME_DATA as /data,
# and DOCKER_VOLUME_RUNTIME as /runtime.
# LOCAL accepts /data/..., /runtime/..., /workspace/..., ./relative paths,
# ${DOCKER_VOLUME_RUNTIME}/tailscale, or {DOCKER_VOLUME_RUNTIME}/tailscale.
# No RCLONE_<index>_* block means pull/sync is skipped.
# RCLONE_0_NAME=tinyauth-db
# RCLONE_0_TAGS=app,data
# RCLONE_0_TYPE=file
# RCLONE_0_LOCAL=${DOCKER_VOLUME_DATA}/rclone/tinyauth-db/tinyauth.db
# RCLONE_0_REMOTE=remote:proxy-stack/tinyauth.db
# RCLONE_0_INTERVAL=300
# RCLONE_0_CONFIG_BASE64=
# RCLONE_0_CONFIG_RAW=

# --- KEY SECRET STORE ENV ---
CI_ENV_FILE_KEY=ENV_FILE
# --- Domain ---
# Default localhost is only for local tests; set a real domain for named tunnels.
DOMAIN=example.com

# --- Caddy ---
CADDY_HTTP_PORT=80
# CADDY_HTTPS_PORT không cần — TLS terminate ở Cloudflare/Tailscale.

# --- Cloudflare named tunnel ---
# https://one.dash.cloudflare.com/ → Networks → Tunnels → token
# Public Hostname → http://caddy:80
CF_TUNNEL_TOKEN=eyJ...replace-me

# --- Tinyauth v5 ---
# APPURL = URL public (https) — cookie + redirect login. Không dùng host nội bộ ở prod.
TINYAUTH_APPURL=https://auth.example.com
TINYAUTH_HOST=http://auth.example.com
# user:password — $$ cho Compose; ./tinyauth/scripts/generate-user.mjs
TINYAUTH_AUTH_USERS=user:$$2a$$10$$UdLYoJ5lgPsC0RKqYH/jMua7zIn0g9kPqWmhYayJYLaZQ/FTmH2/u
TINYAUTH_AUTH_SECURECOOKIE=true
TINYAUTH_DATABASE_PATH=/data/tinyauth/tinyauth.db
TINYAUTH_LOG_LEVEL=info
TINYAUTH_ANALYTICS_ENABLED=false
# Tắt warning UI kiểu "Insecure redirect" khi HTTPS public proxy về HTTP origin.
TINYAUTH_UI_WARNINGSENABLED=false
# Optional TINYAUTH_*: chỉ copy từ tinyauth/.env.example khi CẦN và có giá trị thật.
# Đừng thêm KEY= rỗng (Tinyauth v5 có thể refuse / crash).

# --- Whoami ---
WHOAMI_HOST=http://whoami.example.com
# Default public demo route has no login. Set true to protect whoami with Tinyauth.
WHOAMI_TINYAUTH_ENABLED=false

# --- Admin tools (profile full hoặc từng service riêng) ---
DOZZLE_HOSTS=http://dozzle.example.com, http://logs.example.com
FILEBROWSER_HOST=http://files.example.com
WEBSSH_HOSTS=http://ttyd.example.com, http://webssh.example.com

# --- Tailscale (cần profile full hoặc tailscale) ---
# OAuth client: https://login.tailscale.com/admin/settings/oauth
# TS_CLIENT_ID=
# TS_CLIENT_SECRET=
TS_TAILNET=example.ts.net
TS_TAGS=tag:container,tag:ci
TS_ACL_SAMPLE_PATH=tailscale/acl.sample.hujson
TS_ACL_JSON_PATH=tailscale/acl.hujson
TS_HOSTNAME=proxy-stack
TS_SERVE_CONFIG=/config/serve.json
TS_USERSPACE=true
TS_EXTRA_ARGS=--accept-dns=false

# --- Orchestrator sidecar (RTDB-as-Consul, điều phối leader/con) ---
# Catalog đầy đủ: orchestrator/.env.example
# Bật khi muốn giữ dịch vụ LIỀN MẠCH qua giới hạn ~60' của GHA/Azure.
CONSUL_ENABLE=0
# Service Account JSON (base64) + Database URL — BẮT BUỘC khi CONSUL_ENABLE=1.
# ORCH_RTDB_SERVICE_ACCOUNT=
# ORCH_RTDB_URL=https://<project>-default-rtdb.firebaseio.com
# ORCH_STACK=${DOMAIN}
# Chủ động nhường ghế trước khi job hết 60' (giây, mặc định 3300 = 55').
# ORCH_MAX_LEADER_SECONDS=3300
# Thông tin tuỳ ý ghi lên RTDB: mọi ORCH_META_* → node.meta.<key>
# ORCH_META_REGION=asia-southeast1
# ORCH_META_ENV=production
