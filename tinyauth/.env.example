# =============================================================================
# tinyauth/.env.example — biến môi trường Tinyauth v5
# =============================================================================
#
# Mục đích: đầy đủ nhóm cấu hình TINYAUTH_* (v5). Key lạ → process từ chối start.
# Copy KEY cần dùng vào root .env. Chỉ dùng key có trong docs.
#
# Tài liệu chính:
#   - Configuration: https://tinyauth.app/docs/reference/configuration/
#   - Getting started: https://tinyauth.app/docs/getting-started/
#   - Caddy: https://tinyauth.app/docs/community/caddy/
#   - CLI user create: https://tinyauth.app/docs/reference/cli/
#   - Migrate 4→5: https://tinyauth.app/docs/breaking-updates/4-to-5/
#
# Tạo user (bcrypt):
#   ./tinyauth/scripts/generate-user.mjs
#   hoặc: docker run --rm -it ghcr.io/steveiliop56/tinyauth:v5 user create --interactive
#   Chọn "format for docker" → dùng $$ thay $ trong .env Compose.
#
# Cookie domain:
#   TINYAUTH_APPURL=https://auth.example.com → cookie trên .example.com
#   Cần subdomain thật (auth + app cùng parent), không dùng multi-level free DDNS.
#
# Trong compose dự án (tinyauth/tinyauth.yml):
#   TINYAUTH_APPURL, TINYAUTH_AUTH_USERS, TINYAUTH_AUTH_SECURECOOKIE,
#   TINYAUTH_LOG_LEVEL, TINYAUTH_DATABASE_PATH, TINYAUTH_ANALYTICS_ENABLED
#   + TINYAUTH_HOST (label Caddy, không phải env Tinyauth process)
#
# Profiles: tinyauth | core | full  (COMPOSE_PROFILES ở root .env)
# =============================================================================

# -----------------------------------------------------------------------------
# Profiles (root .env)
# -----------------------------------------------------------------------------
# COMPOSE_PROFILES=core
# COMPOSE_PROFILES=tinyauth,caddy

# -----------------------------------------------------------------------------
# Biến stack (Caddy label — không phải env process Tinyauth)
# -----------------------------------------------------------------------------

# TINYAUTH_HOST
#   Công dụng: Site address Caddy cho UI login (thường http:// vì TLS ở Tunnel).
#   Phải khớp Public Hostname Cloudflare trỏ về caddy:80.
TINYAUTH_HOST=http://auth.example.com

# DOMAIN — dùng default ghép host nếu không set TINYAUTH_* host riêng
DOMAIN=example.com

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------

# TINYAUTH_APPURL  (bắt buộc thực tế để cookie/redirect đúng)
#   Công dụng: URL công khai base của Tinyauth (scheme + host, không path thừa).
#   Prod: https://auth.example.com
#   CI:   http://tinyauth.internal
TINYAUTH_APPURL=https://auth.example.com

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# TINYAUTH_DATABASE_PATH
#   Công dụng: Đường dẫn file SQLite (sessions, state). Volume /data trong compose.
#   Mặc định image: ./tinyauth.db
TINYAUTH_DATABASE_PATH=/data/tinyauth.db

# -----------------------------------------------------------------------------
# Analytics
# -----------------------------------------------------------------------------

# TINYAUTH_ANALYTICS_ENABLED  [true|false]
#   Công dụng:
#     true  — Gửi/thu thập thông tin version định kỳ (default upstream).
#     false — Tắt analytics (khuyến nghị self-host riêng tư).
#   Stack mặc định: false
TINYAUTH_ANALYTICS_ENABLED=false

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------

# TINYAUTH_SERVER_PORT
#   Công dụng: Port listen trong container. Compose/Caddy expect 3000.
#   Mặc định: 3000
# TINYAUTH_SERVER_PORT=3000

# TINYAUTH_SERVER_ADDRESS
#   Công dụng: Bind address. 0.0.0.0 = mọi interface trong container.
#   Mặc định: 0.0.0.0
# TINYAUTH_SERVER_ADDRESS=0.0.0.0

# TINYAUTH_SERVER_SOCKETPATH
#   Công dụng: Unix socket thay TCP (nâng cao).
#   QUAN TRỌNG: KHÔNG ghi KEY= rỗng vào root .env.
#   Key có mặt với value "" vẫn được Tinyauth parse và có thể crash bootstrap
#   (giống “unset” ≠ “set empty”). Chỉ bật khi có path thật, ví dụ:
# TINYAUTH_SERVER_SOCKETPATH=/run/tinyauth.sock

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------

# TINYAUTH_AUTH_USERS  (bắt buộc nếu không dùng USERSFILE / OAuth-only)
#   Công dụng: Danh sách user dạng username:bcrypt[,user2:hash2]
#   Ví dụ (user:password) — $$ để Compose giữ một $:
TINYAUTH_AUTH_USERS=user:$$2a$$10$$UdLYoJ5lgPsC0RKqYH/jMua7zIn0g9kPqWmhYayJYLaZQ/FTmH2/u

# TINYAUTH_AUTH_USERSFILE
#   Công dụng: File chứa users thay vì env (một user / dòng hoặc theo docs).
# TINYAUTH_AUTH_USERSFILE=

# TINYAUTH_AUTH_SECURECOOKIE  [true|false]
#   Công dụng: Flag Secure trên cookie session.
#     true  — Chỉ gửi cookie qua HTTPS. Bắt buộc khi public URL là https://.
#     false — Cho phép HTTP (lab/CI). Không dùng prod public HTTP.
#   Mặc định upstream: false
TINYAUTH_AUTH_SECURECOOKIE=true

# TINYAUTH_AUTH_SESSIONEXPIRY
#   Công dụng: Thời hạn session (giây). Mặc định 86400 (24h).
# TINYAUTH_AUTH_SESSIONEXPIRY=86400

# TINYAUTH_AUTH_SESSIONMAXLIFETIME
#   Công dụng: Tuổi đời tối đa session (giây). 0 = không giới hạn cứng thêm.
# TINYAUTH_AUTH_SESSIONMAXLIFETIME=0

# TINYAUTH_AUTH_LOGINTIMEOUT
#   Công dụng: Cửa sổ timeout login (giây) liên quan rate limit.
#   Mặc định: 300
# TINYAUTH_AUTH_LOGINTIMEOUT=300

# TINYAUTH_AUTH_LOGINMAXRETRIES
#   Công dụng: Số lần login sai tối đa trong cửa sổ timeout.
#   Mặc định: 3
# TINYAUTH_AUTH_LOGINMAXRETRIES=3

# TINYAUTH_AUTH_IP_ALLOW
#   Công dụng: Chỉ cho phép IP/CIDR này (phẩy). Trống = không whitelist.
#   Ví dụ: 10.0.0.0/8,192.168.1.0/24
# TINYAUTH_AUTH_IP_ALLOW=

# TINYAUTH_AUTH_IP_BLOCK
#   Công dụng: Chặn IP/CIDR (phẩy).
# TINYAUTH_AUTH_IP_BLOCK=

# TINYAUTH_AUTH_TRUSTEDPROXIES
#   Công dụng: Proxy tin cậy (phẩy) để lấy client IP thật (X-Forwarded-For).
#   Ví dụ: caddy,172.18.0.0/16
# TINYAUTH_AUTH_TRUSTEDPROXIES=

# -----------------------------------------------------------------------------
# Resources / UI
# -----------------------------------------------------------------------------

# TINYAUTH_RESOURCES_ENABLED  [true|false]
#   Công dụng: Bật/tắt resources server tĩnh. Mặc định true.
# TINYAUTH_RESOURCES_ENABLED=true

# TINYAUTH_RESOURCES_PATH
#   Công dụng: Thư mục resources. Mặc định ./resources
# TINYAUTH_RESOURCES_PATH=

# TINYAUTH_UI_TITLE
#   Công dụng: Tiêu đề trang login.
# TINYAUTH_UI_TITLE=Tinyauth

# TINYAUTH_UI_FORGOTPASSWORDMESSAGE
#   Công dụng: Message trang quên mật khẩu.
# TINYAUTH_UI_FORGOTPASSWORDMESSAGE=

# TINYAUTH_UI_BACKGROUNDIMAGE
#   Công dụng: Path ảnh nền. Mặc định /background.jpg
# TINYAUTH_UI_BACKGROUNDIMAGE=

# TINYAUTH_UI_WARNINGSENABLED  [true|false]
#   Công dụng: Hiện warning UI (misconfig). Mặc định true.
# TINYAUTH_UI_WARNINGSENABLED=true

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

# TINYAUTH_LOG_LEVEL  [chọn 1 giá trị]
#   Công dụng: Mức log toàn cục.
#   Giá trị hợp lệ:
#     trace — Cực chi tiết; CÓ THỂ lộ username/email/ACL. Chỉ debug ngắn.
#     debug — Debug chi tiết hơn info.
#     info  — Mặc định vận hành.
#     warn  — Cảnh báo.
#     error — Chỉ lỗi.
TINYAUTH_LOG_LEVEL=info

# TINYAUTH_LOG_JSON  [true|false]
#   Công dụng: true = log JSON; false = text.
# TINYAUTH_LOG_JSON=false

# TINYAUTH_LOG_STREAMS_HTTP_ENABLED / _LEVEL
# TINYAUTH_LOG_STREAMS_APP_ENABLED / _LEVEL
# TINYAUTH_LOG_STREAMS_AUDIT_ENABLED / _LEVEL
#   Công dụng: Bật/tắt từng stream log; LEVEL để trống = theo global.
# TINYAUTH_LOG_STREAMS_HTTP_ENABLED=true
# TINYAUTH_LOG_STREAMS_APP_ENABLED=true
# TINYAUTH_LOG_STREAMS_AUDIT_ENABLED=false

# -----------------------------------------------------------------------------
# OAuth (tuỳ chọn — điền khi dùng Google/GitHub/generic)
# -----------------------------------------------------------------------------
# Docs: configuration → OAuth
#
# TINYAUTH_OAUTH_WHITELIST
#   Công dụng: Domain/email OAuth được phép (phẩy).
# TINYAUTH_OAUTH_WHITELIST=
#
# TINYAUTH_OAUTH_AUTOREDIRECT  [tên provider]
#   Công dụng: Tự redirect login sang provider này (ví dụ google, github).
# TINYAUTH_OAUTH_AUTOREDIRECT=
#
# Provider built-in id `google` / `github` tự fill auth URL; chỉ cần:
#   Chỉ thêm các dòng dưới khi có client id/secret THẬT (đừng để value rỗng):
#   TINYAUTH_OAUTH_PROVIDERS_GOOGLE_CLIENTID=...
#   TINYAUTH_OAUTH_PROVIDERS_GOOGLE_CLIENTSECRET=...
#   TINYAUTH_OAUTH_PROVIDERS_GITHUB_CLIENTID=...
#   TINYAUTH_OAUTH_PROVIDERS_GITHUB_CLIENTSECRET=...
#
# Generic provider NAME (thay NAME):
#   TINYAUTH_OAUTH_PROVIDERS_NAME_CLIENTID=
#   TINYAUTH_OAUTH_PROVIDERS_NAME_CLIENTSECRET=
#   TINYAUTH_OAUTH_PROVIDERS_NAME_CLIENTSECRETFILE=
#   TINYAUTH_OAUTH_PROVIDERS_NAME_SCOPES=
#   TINYAUTH_OAUTH_PROVIDERS_NAME_REDIRECTURL=
#   TINYAUTH_OAUTH_PROVIDERS_NAME_AUTHURL=
#   TINYAUTH_OAUTH_PROVIDERS_NAME_TOKENURL=
#   TINYAUTH_OAUTH_PROVIDERS_NAME_USERINFOURL=
#   TINYAUTH_OAUTH_PROVIDERS_NAME_INSECURE=false
#   TINYAUTH_OAUTH_PROVIDERS_NAME_NAME=

# -----------------------------------------------------------------------------
# Per-app ACL (tuỳ chọn) — TINYAUTH_APPS_<NAME>_*
# -----------------------------------------------------------------------------
# Docs: configuration → ACLs
# Ví dụ app "whoami":
#   TINYAUTH_APPS_WHOAMI_CONFIG_DOMAIN=https://whoami.example.com
#   TINYAUTH_APPS_WHOAMI_USERS_ALLOW=user,admin
#   TINYAUTH_APPS_WHOAMI_USERS_BLOCK=
#   TINYAUTH_APPS_WHOAMI_OAUTH_WHITELIST=
#   TINYAUTH_APPS_WHOAMI_OAUTH_GROUPS=
#   TINYAUTH_APPS_WHOAMI_IP_ALLOW=
#   TINYAUTH_APPS_WHOAMI_IP_BLOCK=
#   TINYAUTH_APPS_WHOAMI_IP_BYPASS=
#   TINYAUTH_APPS_WHOAMI_PATH_ALLOW=
#   TINYAUTH_APPS_WHOAMI_PATH_BLOCK=
#   TINYAUTH_APPS_WHOAMI_LDAP_GROUPS=
#   TINYAUTH_APPS_WHOAMI_RESPONSE_HEADERS=
#   TINYAUTH_APPS_WHOAMI_RESPONSE_BASICAUTH_USERNAME=
#   TINYAUTH_APPS_WHOAMI_RESPONSE_BASICAUTH_PASSWORD=

# -----------------------------------------------------------------------------
# LDAP / OIDC (tuỳ chọn — xem docs đầy đủ)
# -----------------------------------------------------------------------------
# TINYAUTH_LDAP_ADDRESS=
# TINYAUTH_LDAP_BINDDN=
# TINYAUTH_LDAP_BINDPASSWORD=
# TINYAUTH_LDAP_BASEDN=
# TINYAUTH_LDAP_INSECURE=false
# TINYAUTH_LDAP_SEARCHFILTER=(uid=%s)
#
# TINYAUTH_OIDC_PRIVATEKEYPATH=
# TINYAUTH_OIDC_PUBLICKEYPATH=
# TINYAUTH_OIDC_CLIENTS_<NAME>_CLIENTID=
# TINYAUTH_OIDC_CLIENTS_<NAME>_CLIENTSECRET=
# TINYAUTH_OIDC_CLIENTS_<NAME>_TRUSTEDREDIRECTURIS=
