{
  "name": "docker-caddy-tailscale-tinyauth",
  "version": "1.0.0",
  "private": true,
  "description": "Modular Docker reverse-proxy stack: Cloudflare Tunnel, Tailscale, Caddy, Tinyauth",
  "scripts": {
    "user": "node tinyauth/scripts/generate-user.mjs --env .env.dockercaddytailscaletinyauth",
    "user:docker": "docker run --rm -it ghcr.io/steveiliop56/tinyauth:v5 user create --interactive",
    "up": "node scripts/up.mjs",
    "up:core": "node scripts/up.mjs core",
    "up:full": "node scripts/up.mjs full",
    "add-app": "node scripts/addapp/add-app.mjs",
    "validate-apps": "node scripts/addapp/validate-app.mjs",
    "gen-app-ci": "node scripts/addapp/gen-app-ci.mjs",
    "down": "docker compose down --remove-orphans",
    "logs": "docker compose logs -f --tail=100",
    "ps": "docker compose ps",
    "config": "docker compose config",
    "tunnel-url": "node cloudflare/scripts/extract-tunnel-url.mjs",
    "litestream:config": "node litestream/scripts/generate-config.mjs",
    "litestream:restore": "node litestream/scripts/restore.mjs",
    "rclone:pull": "node rclone/scripts/pull.mjs",
    "ssh:env": "node nodesync/scripts/ssh-setup-env.mjs --env .env.dockercaddytailscaletinyauth",
    "ssh:nodesync": "ssh -i .secret/nodesync_id_ed25519 -o IdentitiesOnly=yes -o PubkeyAuthentication=yes -o PasswordAuthentication=yes -o ProxyCommand=\"cloudflared access ssh --hostname ssh.dockercaddytailscaletinyauth.dpdns.org\" nodesync@ssh.dockercaddytailscaletinyauth.dpdns.org",
    "provision": "node cloudflare/scripts/provision-tunnel.mjs --env .env.dockercaddytailscaletinyauth",
    "ts-status": "node tailscale/scripts/status.mjs",
    "ts-init": "node tailscale/scripts/init.mjs --env .env.dockercaddytailscaletinyauth",
    "ts-init:dry": "node tailscale/scripts/init.mjs --env .env.dockercaddytailscaletinyauth --dry-run"
  },
  "devDependencies": {
    "bcryptjs": "^2.4.3",
    "jsonc-parser": "^3.3.1"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
